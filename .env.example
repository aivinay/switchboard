# Switchboard local settings
# The `ICP_` prefix is the historical settings prefix, kept for backward compatibility.
ICP_ENVIRONMENT=local
ICP_DATABASE_URL=sqlite:///./switchboard.db
ICP_MODELS_CONFIG_PATH=config/models.yaml
ICP_POLICIES_CONFIG_PATH=config/policies.yaml
ICP_PERSONAL_CONFIG_PATH=config/personal.yaml
ICP_LOG_PROMPTS=false
ICP_LOG_RESPONSES=false

# Optional real provider keys. Not required for local development or tests.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
